{
  "expo": {
    "name": "Werkant",
    "slug": "werkr",
    "version": "1.0.0",
    "sdkVersion": "56.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "werkant",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#17503A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.werkant.app",
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Werkant benötigt Kamerazugriff für Fotos deiner Leistungen.",
        "NSPhotoLibraryUsageDescription": "Werkant benötigt Zugriff auf deine Fotos für Profilbild und Auftragsdokumentation.",
        "NSPhotoLibraryAddUsageDescription": "Werkant speichert Auftragsfotos in deiner Fotomediathek.",
        "NSMicrophoneUsageDescription": "Werkant benötigt das Mikrofon für Sprachnachrichten im Chat.",
        "NSLocationWhenInUseUsageDescription": "Werkant nutzt deinen Standort, um Anbieter in deiner Nähe zu finden.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#17503A"
      },
      "predictiveBackGestureEnabled": false,
      "allowBackup": false,
      "package": "de.werkant.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "lang": "de",
      "backgroundColor": "#17503A",
      "meta": {
        "description": "Werkant — die Plattform für lokale Handwerksleistungen",
        "og:title": "Werkant",
        "og:description": "Handwerker finden & beauftragen — schnell, fair, rechtssicher."
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.de.werkant.app",
          "enableGooglePay": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#1C6B45",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "werkr-placeholder-replace-with-real-eas-id"
      },
      "privacyPolicyUrl": "https://23mta23-cpu.github.io/Ruflo/datenschutz"
    }
  }
}
