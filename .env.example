# WERKR — Environment Variables Template
# Copy to .env.local and fill in your values.
# .env.local is gitignored — NEVER commit real credentials.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL (find in Supabase Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable (anon) key — safe to use in client bundle (enforced by RLS)
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
# Publishable key only — NEVER put the secret key here
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key

# ── App config ────────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development   # development | staging | production
